{
  "name": "react-dynadux",
  "version": "4.0.0",
  "description": "React Provider for Dynadux stores",
  "repository": {
    "type": "git",
    "url": "https://github.com/aneldev/react-dynadux"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "scripts": {
    "create": "echo Creation started... && rm -rf .git && rm -rf pnpm.lock; mv README.md README.boilerplate.md && echo \\# readme > README.md && pnpm install && node _boilerplateCreateModule.js && echo --- module created",
    "install-clean": "rm -rf node_modules; pnpm install",
    "start": "webpack-dev-server --config webpack.dev.config.js --devtool eval --progress --hot --open --host localhost --port 3200 ",
    "start-at": "webpack-dev-server --config webpack.dev.config.js --devtool eval --progress --hot --open --host localhost --port",
    "build-analyze": "webpack --config webpack.dist.analyze.config.js",
    "build": "pnpm lint && rm -rf ./dist; pnpm build-ts-declarations && webpack --config webpack.dist.config.js",
    "build-watch": "rm -rf ./dist; pnpm build-ts-declarations && webpack --watch --config webpack.dist.config.js",
    "build-ts-declarations": "node tsconfig.update.js && tsc && cd dist/ && find . -name \\*.js -delete && cd ..",
    "storybook": "start-storybook -p 9200",
    "storybook-at": "start-storybook -p",
    "commit": "git add -u && git add -A && git commit --allow-empty -m",
    "commit-amend": "git add -u && git add -A && git commit --amend --allow-empty --no-edit",
    "lint": "eslint -c .eslintrc.js ./src ./tests",
    "lint-fix": "eslint -c .eslintrc.js --fix ./src ./tests",
    "test": "jest --coverage --no-cache --runInBand",
    "test-debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test-watch": "jest --watch --verbose --runInBand",
    "test-no-coverage": "jest --no-cache --runInBand",
    "test-update-snapshots": "jest --updateSnapshot --runInBand",
    "update-all-deps": "pnpm update --latest",
    "publish-push": "pnpm version patch && pnpm publish --non-interactive && git push && git push --tags",
    "release": "pnpm build && pnpm test && git add -u && git add -A && git commit --allow-empty -m \"Build changes\" && pnpm publish-push"
  },
  "keywords": [
    "react",
    "dynadux",
    "redux"
  ],
  "author": "Anel dev",
  "license": "MIT",
  "dependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "dyna-debounce": "^2.0.2",
    "dynadux": "^2.3.6",
    "react-refresh": "^0.14.2"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.1.2",
    "@babel/core": "^7.11.4",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.24.7",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.0.0",
    "@storybook/addon-controls": "^8.2.9",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/react": "^8.2.9",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^27.0.1",
    "@types/node": "^10.12.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^5.5.0",
    "@typescript-eslint/parser": "^5.5.0",
    "autoprefixer": "^7.2.6",
    "babel-jest": "^26.6.3",
    "babel-loader": "^8.1.0",
    "babel-preset-minify": "^0.5.1",
    "babel-preset-react-app": "^10.0.1",
    "circular-dependency-plugin": "^5.2.2",
    "css-loader": "^1.0.1",
    "dyna-guid": "^2.1.2",
    "dyna-node-arguments": "^2.0.1",
    "dyna-node-fs": "^1.0.4",
    "dyna-showcase": "^3.0.1",
    "eslint": "^7.32.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-etc": "^2.0.1",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jest": "^25.3.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.3.0",
    "file-loader": "^2.0.0",
    "html-webpack-plugin": "^5.6.0",
    "identity-obj-proxy": "^3.0.0",
    "image-webpack-loader": "^8.1.0",
    "jest": "^28.1.3",
    "jest-cli": "^26.6.3",
    "jest-electron": "^0.1.12",
    "jest-junit": "^12.0.0",
    "jsdom": "^16.4.0",
    "jsdom-global": "^3.0.2",
    "less": "^3.9.0",
    "less-loader": "^4.1.0",
    "postcss-cli": "^4.1.0",
    "postcss-flexbugs-fixes": "3.2.0",
    "postcss-loader": "^2.1.6",
    "raw-loader": "^0.5.1",
    "react-test-renderer": "^18.3.1",
    "sass-loader": "^7.1.0",
    "source-map-loader": "0.1.5",
    "style-loader": "^0.23.1",
    "svg-inline-loader": "^0.8.0",
    "ts-jest": "^28.0.8",
    "ts-loader": "^8.3.0",
    "typescript": "^5.5.4",
    "typings-for-css-modules-loader": "^1.7.0",
    "uglifyjs-webpack-plugin": "^2.2.0",
    "url-loader": "^0.5.9",
    "webpack": "^5.93.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-node-externals": "^3.0.0"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./tests/setup/testSetup.ts"
    ],
    "automock": false,
    "collectCoverage": false,
    "runner": "jest-electron/runner",
    "testEnvironment": "jest-electron/environment",
    "transform": {
      ".(ts|tsx)": "ts-jest"
    },
    "testRegex": "(src|tests)/.*\\.(test|spec)\\.(ts|tsx|js|jsx)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|jpg|png|svg|gif)$": "identity-obj-proxy"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx,js,jsx}",
      "!src/**/*.d.ts"
    ]
  },
  "jest-junit": {
    "output": "./coverage/junit.xml"
  },
  "engines": {
    "npm": ">=10.0.0 <11.0.0",
    "node": ">=20.0.0 <21.0.0"
  }
}
